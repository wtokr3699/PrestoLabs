rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 프로젝트: 비로그인도 목록/검색 가능
    match /projects/{id} {
      allow read: if true;
    }

    // 리뷰: 비로그인도 프리랜서 프로필에서 열람 가능
    match /reviews/{id} {
      allow read: if true;
    }

    // 유저 프로필: 본인 또는 공개된 프리랜서 프로필만 읽기
    match /users/{uid} {
      allow read: if request.auth != null
                  && (request.auth.uid == uid
                      || (resource.data.role == "freelancer"
                          && resource.data.profileComplete == true
                          && resource.data.deletedAt == null));
    }

    // 알림: 본인(userId 필드)만 읽기
    match /notifications/{id} {
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.userId;
    }

    // 북마크: 본인(userId 필드)만 읽기
    match /bookmarks/{id} {
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.userId;
    }

    // 지원서: 지원자 본인 또는 프로젝트 의뢰인만 읽기
    match /applications/{id} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.freelancerId
                      || request.auth.uid == get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.clientId);
    }

    // 계약서: 의뢰인(clientId) 또는 프리랜서(freelancerId)만 읽기
    match /contracts/{id} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.clientId
                      || request.auth.uid == resource.data.freelancerId);
    }

    // 결제: 의뢰인(clientId) 또는 프리랜서(freelancerId)만 읽기
    match /payments/{id} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.clientId
                      || request.auth.uid == resource.data.freelancerId);
    }

    // ※ 쓰기 규칙 없음 = 전부 차단
    // 모든 데이터 쓰기는 /api/* 라우트(Firebase Admin SDK)를 통해서만 처리.
    // Admin SDK는 보안 규칙을 우회하므로 여기 쓰기 규칙은 불필요.
    // 클라이언트가 직접 쓰기를 허용하면 서버 검증 로직(역할 확인,
    // 상태 머신, 중복 방지 등)을 우회할 수 있어 오히려 위험합니다.
  }
}
