# Firebase Client
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (서비스 계정 키 - 서버 전용)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Toss Payments Sandbox
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# LLM API
LLM_API_KEY=
LLM_PROVIDER=anthropic

# 크론 작업 인증 (마감일 처리). 미설정 시 /api/cron/* 비활성화
CRON_SECRET=

# 시드 엔드포인트 인증. 미설정 시 /api/seed/* 비활성화 (요청 헤더 x-seed-secret 로 전달)
SEED_SECRET=

# 샌드박스 결제 허용 플래그 (로컬 개발 전용). "true" 일 때만 sandbox_pk_ 결제 우회 허용
ALLOW_SANDBOX_PAYMENTS=
